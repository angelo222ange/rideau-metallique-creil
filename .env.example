# DRM CREIL - Variables d'environnement
# ═══════════════════════════════════════════════════════════════════════════
# Copier ce fichier en .env et remplir les valeurs
# ATTENTION : .env ne doit JAMAIS être push sur GitHub (inclus dans .gitignore)

# Webhook n8n pour le formulaire de contact
NEXT_PUBLIC_WEBHOOK_URL=https://lioai.app.n8n.cloud/webhook/drm-contact

# Google Analytics (optionnel)
NEXT_PUBLIC_GA_ID=

# Google Search Console (optionnel)
GOOGLE_SITE_VERIFICATION=
